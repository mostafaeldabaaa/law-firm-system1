<!DOCTYPE html>
<html lang="<%= locale %>" dir="<%= dir %>">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title><%= title %></title>
</head>
<body style="margin:0; padding:0; background-color:#F4F1EC; font-family: Arial, Helvetica, sans-serif;">
  <table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="background-color:#F4F1EC; padding: 32px 16px;">
    <tr>
      <td align="center">
        <table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="max-width: 480px; background-color:#FFFFFF; border-radius: 8px; overflow:hidden; border: 1px solid #E5E0D8;">

          <tr>
            <td style="background-color:#0F1E2E; padding: 24px 32px;" align="<%= dir === 'rtl' ? 'right' : 'left' %>">
              <span style="color:#B08D57; font-size: 20px; font-weight: bold; letter-spacing: 0.5px;">
                <%= firmName %>
              </span>
            </td>
          </tr>

          <tr>
            <td style="padding: 32px;" align="<%= dir === 'rtl' ? 'right' : 'left' %>">
              <p style="margin:0 0 16px 0; color:#0F1E2E; font-size: 18px; font-weight: bold; line-height: 1.6;">
                <%= greeting %>
              </p>
              <p style="margin:0 0 24px 0; color:#4A4A4A; font-size: 14px; line-height: 1.6;">
                <%= welcomeMessage %>
              </p>

              <table role="presentation" cellpadding="0" cellspacing="0">
                <tr>
                  <td style="border-radius: 6px; background-color:#B08D57;">
                    <a href="<%= dashboardUrl %>" target="_blank" style="display:inline-block; padding: 12px 28px; color:#FFFFFF; font-size: 14px; font-weight: bold; text-decoration:none;">
                      <%= ctaLabel %>
                    </a>
                  </td>
                </tr>
              </table>
            </td>
          </tr>

          <tr>
            <td style="padding: 20px 32px; background-color:#F4F1EC; border-top: 1px solid #E5E0D8;" align="center">
              <span style="color:#9A9A9A; font-size: 12px;">
                &copy; <%= year %> <%= firmName %>. <%= rightsReserved %>
              </span>
            </td>
          </tr>

        </table>
      </td>
    </tr>
  </table>
</body>
</html>
